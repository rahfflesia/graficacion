generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model metodossubprocesos {
  idmetodosubproceso   Int                 @id @default(autoincrement())
  idsubproceso         Int
  idtecnicarecoleccion Int
  subprocesos          subprocesos         @relation(fields: [idsubproceso], references: [idsubproceso], onDelete: Cascade, onUpdate: NoAction, map: "fk_metodossubprocesos_subprocesos")
  tecnicasrecoleccion  tecnicasrecoleccion @relation(fields: [idtecnicarecoleccion], references: [idtecnicarecoleccion], onDelete: NoAction, onUpdate: NoAction, map: "fk_metodossubprocesos_tecnicarsecoleccion")
}

model procesos {
  idproceso     Int           @id @default(autoincrement())
  nombre        String        @db.VarChar(255)
  descripcion   String
  fechacreacion DateTime      @default(now()) @db.Timestamptz(6)
  idproyecto    Int
  proyectos     proyectos     @relation(fields: [idproyecto], references: [idproyecto], onDelete: NoAction, onUpdate: NoAction, map: "fk_proyecto_procesos")
  subprocesos   subprocesos[]
}

model proyectos {
  idproyecto            Int                     @id @default(autoincrement())
  nombre                String                  @db.VarChar(255)
  descripcion           String
  fechacreacion         DateTime                @default(now()) @db.Timestamptz(6)
  idusuario             Int
  estado                estadosproyectos        @default(Activo)
  procesos              procesos[]
  usuarios              usuarios                @relation(fields: [idusuario], references: [idusuario], onDelete: NoAction, onUpdate: NoAction, map: "fk_proyectos_usuarios")
  roles                 roles[]
  rolespersonasproyecto rolespersonasproyecto[]
}

model roles {
  idrol                 Int                     @id @default(autoincrement())
  idproyecto            Int
  nombre                String?                 @db.VarChar(255)
  tipo                  tiporol
  proyectos             proyectos               @relation(fields: [idproyecto], references: [idproyecto], onDelete: NoAction, onUpdate: NoAction, map: "fk_roles_proyecto")
  rolespersonasproyecto rolespersonasproyecto[]
}

model tecnicasrecoleccion {
  idtecnicarecoleccion Int                  @id @default(autoincrement())
  nombre               String               @db.VarChar(128)
  descripcion          String
  metodossubprocesos   metodossubprocesos[]
}

model personas {
  idpersona               Int                       @id @default(autoincrement())
  nombre                  String                    @db.VarChar(255)
  apellidouno             String                    @db.VarChar(255)
  apellidodos             String?                   @db.VarChar(255)
  correo                  String?                   @db.VarChar(255)
  telefono                String?                   @db.VarChar(255)
  observaciones           observaciones[]
  observacionesobservados observacionesobservados[]
  rolespersonasproyecto   rolespersonasproyecto[]
  cuestionarios           cuestionarios[]
  respuestascuestionario respuestascuestionario[]
  historiasusuario historiasusuario[]
}

model rolespersonasproyecto {
  idrolpersonaproyecto Int         @id @default(autoincrement())
  idpersona            Int
  idrol                Int
  idproyecto           Int
  tipo                 tipousuario
  personas             personas    @relation(fields: [idpersona], references: [idpersona], onDelete: NoAction, onUpdate: NoAction, map: "fk_rolespersonasproyecto_persona")
  proyectos            proyectos   @relation(fields: [idproyecto], references: [idproyecto], onDelete: NoAction, onUpdate: NoAction, map: "fk_rolespersonasproyecto_proyecto")
  roles                roles       @relation(fields: [idrol], references: [idrol], onDelete: NoAction, onUpdate: NoAction, map: "fk_rolespersonasproyecto_rol")

  @@unique([idpersona, idproyecto])
}

model subprocesos {
  idsubproceso       Int                  @id @default(autoincrement())
  idproceso          Int
  nombre             String               @db.VarChar(255)
  descripcion        String
  fechacreacion      DateTime             @default(now()) @db.Timestamptz(6)
  metodossubprocesos metodossubprocesos[]
  observaciones      observaciones[]
  procesos           procesos             @relation(fields: [idproceso], references: [idproceso], onDelete: Cascade, onUpdate: NoAction, map: "fk_subprocesos_procesos")
  cuestionarios          cuestionarios[]
  historiasusuario historiasusuario[]
}

model usuarios {
  idusuario           Int         @id @default(autoincrement())
  nombre              String      @unique(map: "nombre_unico") @db.VarChar(255)
  hashcontrasena      String      @db.VarChar(255)
  fechacreacioncuenta DateTime    @default(now()) @db.Timestamptz(6)
  correo              String      @unique(map: "correo_unico") @db.VarChar(255)
  pfp                 String?     @default("https://pbs.twimg.com/media/FeToVEqX0Acjv0i.png") @db.VarChar(255)
  proyectos           proyectos[]
}

model observaciones {
  idobservacion           Int                       @id @default(autoincrement())
  idsubproceso            Int
  nombre                  String                    @db.VarChar(255)
  descripcion             String
  idobservador            Int
  lugar                   String                    @db.VarChar(255)
  tipo                    tipoobservacion
  fechahoracaptura        DateTime                  @default(now()) @db.Timestamptz(6)
  personas                personas                  @relation(fields: [idobservador], references: [idpersona], onDelete: NoAction, onUpdate: NoAction)
  subprocesos             subprocesos               @relation(fields: [idsubproceso], references: [idsubproceso], onDelete: Cascade, onUpdate: NoAction)
  observacionesobservados observacionesobservados[]
}

model observacionesobservados {
  idobservacion Int
  idobservado   Int
  observaciones observaciones @relation(fields: [idobservacion], references: [idobservacion], onDelete: NoAction, onUpdate: NoAction)
  personas      personas      @relation(fields: [idobservado], references: [idpersona], onDelete: NoAction, onUpdate: NoAction)

  @@id([idobservacion, idobservado])
}

enum tiporol {
  Interno
  Externo
}

enum tipousuario {
  Persona
  Usuario
}

enum estadosproyectos {
  Activo
  Pausado
  Cancelado
  En_revisi_n @map("En revisión")
}

enum tipoobservacion {
  Pasiva
  Activa
}

model cuestionarios {
  idicuestionario        Int                    @id @default(autoincrement())
  idsubproceso           Int
  nombre                 String                 @db.VarChar(255)
  descripcion            String
  idcreador              Int
  fechacreacion          DateTime               @default(now()) @db.Timestamptz(6)
  personas               personas               @relation(fields: [idcreador], references: [idpersona], onDelete: NoAction, onUpdate: NoAction)
  subprocesos            subprocesos            @relation(fields: [idsubproceso], references: [idsubproceso], onDelete: Cascade, onUpdate: NoAction)
  preguntascuestionario  preguntascuestionario[]
  respuestascuestionario respuestascuestionario[]
}

model preguntascuestionario {
  idpregunta      Int            @id @default(autoincrement())
  idcuestionario  Int
  textopregunta   String
  tipopregunta    tipopregunta
  opciones        String[]       @default([])
  orden           Int
  cuestionarios   cuestionarios  @relation(fields: [idcuestionario], references: [idicuestionario], onDelete: Cascade, onUpdate: NoAction)
  respuestaspreguntas    respuestaspreguntas[]
}

enum tipopregunta {
  Abierta
  Opcion_multiple @map("Opción múltiple")
  Escala
}

model respuestascuestionario {
  idrespuesta        Int                   @id @default(autoincrement())
  idcuestionario     Int
  idrespondente      Int
  fecharespuesta     DateTime              @default(now()) @db.Timestamptz(6)
  cuestionarios      cuestionarios         @relation(fields: [idcuestionario], references: [idicuestionario], onDelete: Cascade, onUpdate: NoAction)
  personas           personas              @relation(fields: [idrespondente], references: [idpersona], onDelete: NoAction, onUpdate: NoAction)
  respuestaspreguntas respuestaspreguntas[]
}

model respuestaspreguntas {
  idrespuestapregunta    Int                      @id @default(autoincrement())
  idrespuesta            Int
  idpregunta             Int
  valor                  String
  respuestascuestionario respuestascuestionario   @relation(fields: [idrespuesta], references: [idrespuesta], onDelete: Cascade, onUpdate: NoAction)
  preguntascuestionario  preguntascuestionario    @relation(fields: [idpregunta], references: [idpregunta], onDelete: Cascade, onUpdate: NoAction)
}

model historiasusuario {
  idhistoriausuario   Int         @id @default(autoincrement())
  idsubproceso        Int
  idcreador           Int
  rolusuario          String      @db.VarChar(255)
  necesidad           String
  beneficio           String
  criteriosaceptacion String[]    @default([])
  prioridad           String      @db.VarChar(20)
  fechacreacion       DateTime    @default(now()) @db.Timestamptz(6)
  personas            personas    @relation(fields: [idcreador], references: [idpersona], onDelete: NoAction, onUpdate: NoAction)
  subprocesos         subprocesos @relation(fields: [idsubproceso], references: [idsubproceso], onDelete: Cascade, onUpdate: NoAction)
}
